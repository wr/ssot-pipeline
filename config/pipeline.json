{
  "$schema": "./pipeline.schema.json",
  "version": 1,
  "plan_marker": "### 📋 Plan",
  "needs_input_marker": "### ⏳ Awaiting input",
  "agent_sessions_enabled": true,
  "linear_mcp_url": "https://mcp.linear.app/mcp",
  "linear_mcp_transport": "http",
  "planning_state": "Planning",
  "plan_review_state": "Plan Review",
  "in_progress_state": "In Progress",
  "in_review_state": "In Review",
  "stuck_state": "Stuck",
  "approval_phrases": ["ship it", "ship", "lgtm", "looks good", "approve", "approved", "accepted", "go for it", "send it", "do it", "punch it", "yolo", "make it so", "let's go", "👍", "✅", "🚀"],
  "branch_prefix": "wells/",
  "pr_fix_max_attempts": 2,
  "review_bot_login": "wr-claude-reviewer[bot]",
  "fix_reviewer_logins": ["wr-claude-reviewer[bot]", "wr"],
  "approved_user_ids": [],
  "enforce_approved_users": false,
  "ceo": {
    "enabled": false,
    "briefing_marker": "## 🧭 CEO Briefing",
    "chairman_linear_handle": "wells",
    "chairman_github_login": "wr",
    "digest_issue_id": "W-358",
    "autonomy": {
      "create_issues": true,
      "refine_and_prioritize": true,
      "delegate_to_loop": true,
      "approve_plans": false,
      "auto_merge": false
    },
    "guardrails": {
      "max_delegations_per_run": 1,
      "max_actions_per_run": 8,
      "max_pr_additions": 400,
      "max_pr_files": 15,
      "require_reviewer_approval": true,
      "require_all_checks_green": true,
      "protected_paths": [
        "config/pipeline.json",
        ".github/workflows/",
        ".github/actions/",
        "worker/wrangler.toml",
        "worker/.dev.vars*",
        "docs/security.md",
        "**/*.pem",
        "**/secret*",
        "**/.env*"
      ]
    },
    "escalation": {
      "always_escalate": [
        "any change to secrets, auth, tokens, or the CEO's own guardrails/config",
        "deleting or cancelling an issue that a human created",
        "spending or billing changes",
        "anything the run is less than confident is safe and reversible"
      ]
    }
  },
  "project_to_repo": {
    "f9eb7447-31fb-4e02-b46b-7d147f2d0f55": "wr/ssot-pipeline",
    "08a62212-7546-4dee-b7c4-0ffed3fff097": "wr/mojito",
