#!/usr/bin/env bash
# Pre-flight health checker for an ssot-pipeline fork.
#
# Checks every credential, every wiring, every endpoint that the loop needs
# in order to function. Prints a colour-coded pass/fail summary and an
# exit code: 0 if everything's green, 1 if anything is missing or broken.
#
# Designed to be runnable standalone (`./bin/doctor`) and also from inside
# bin/setup after each phase, as a sanity check.
#
# Usage:
#   ./bin/doctor              # check this fork end-to-end
#   ./bin/doctor --quiet      # only print failures
#   ./bin/doctor --repo R     # also check target repo R has 4 secrets + 1 var

set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
CONFIG="$REPO_ROOT/config/pipeline.json"

QUIET=0
EXTRA_REPOS=()
while [ $# -gt 0 ]; do
  case "$1" in
    --quiet) QUIET=1; shift ;;
    --repo)  EXTRA_REPOS+=("$2"); shift 2 ;;
    -h|--help) sed -n '2,15p' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;
    *) echo "Unknown flag: $1" >&2; exit 2 ;;
  esac
done

if [ -t 1 ]; then
  C_RESET=$'\033[0m'; C_OK=$'\033[32m'; C_FAIL=$'\033[31m'; C_WARN=$'\033[33m'; C_HDR=$'\033[1;36m'
else
  C_RESET=""; C_OK=""; C_FAIL=""; C_WARN=""; C_HDR=""
fi

FAIL_COUNT=0
WARN_COUNT=0
pass()   { [ "$QUIET" = "1" ] || printf "  ${C_OK}✓${C_RESET} %s\n" "$*"; }
fail()   { printf "  ${C_FAIL}✗${C_RESET} %s\n" "$*"; FAIL_COUNT=$((FAIL_COUNT+1)); }
warn()   { printf "  ${C_WARN}!${C_RESET} %s\n" "$*"; WARN_COUNT=$((WARN_COUNT+1)); }
phase()  { [ "$QUIET" = "1" ] || printf "\n${C_HDR}== %s ==${C_RESET}\n" "$*"; }
hint()   { [ "$QUIET" = "1" ] || printf "       %s\n" "$*"; }

is_macos() { [ "$(uname)" = "Darwin" ] && command -v security >/dev/null 2>&1; }
kc_get() {
  is_macos && security find-generic-password -w -s ssot-pipeline -a "$1" 2>/dev/null || true
}

# --- 1. prereqs -----------------------------------------------------------

phase "Prereqs"
for cmd in gh jq node python3 git curl; do
  if command -v "$cmd" >/dev/null 2>&1; then
    pass "$cmd present"
  else
    fail "$cmd missing"
    hint "Install: brew install $cmd  (or apt/dnf equivalent)"
  fi
done
if gh auth status >/dev/null 2>&1; then
  pass "gh authenticated as $(gh api user --jq .login 2>/dev/null)"
else
  fail "gh not authenticated"
  hint "Fix: gh auth login"
fi

# --- 2. local secret store (Keychain) -------------------------------------

phase "Local credentials (macOS Keychain)"
if ! is_macos; then
  warn "Not on macOS — Keychain checks skipped; rely on env vars instead"
else
  for name in LINEAR_APP_TOKEN CLAUDE_REVIEWER_APP_ID CLAUDE_REVIEWER_APP_KEY \
              CLAUDE_CODE_OAUTH_TOKEN SSOT_WORKER_URL; do
    if [ -n "$(kc_get "$name")" ]; then
      pass "$name in Keychain"
    else
      # CLAUDE_CODE_OAUTH_TOKEN may legitimately live only as env var if you
      # use anthropic_api_key; warn instead of fail.
      if [ "$name" = "CLAUDE_CODE_OAUTH_TOKEN" ]; then
        warn "$name not in Keychain (OK if you use ANTHROPIC_API_KEY instead)"
      else
        fail "$name missing from Keychain"
        hint "Seed: security add-generic-password -U -s ssot-pipeline -a $name -w '<value>'"
      fi
    fi
  done
fi

# --- 3. Linear token works ------------------------------------------------

phase "Linear API"
LINEAR_TOKEN="${LINEAR_APP_TOKEN:-$(kc_get LINEAR_APP_TOKEN)}"
if [ -z "$LINEAR_TOKEN" ]; then
  fail "no LINEAR_APP_TOKEN available — skipping API probe"
else
  RESP=$(curl -sS -X POST https://api.linear.app/graphql \
    -H "Authorization: $LINEAR_TOKEN" \
    -H "Content-Type: application/json" \
    -d '{"query":"{ viewer { name id } }"}' 2>/dev/null || true)
  VIEWER_NAME=$(printf '%s' "$RESP" | jq -r '.data.viewer.name // ""' 2>/dev/null)
  if [ -z "$VIEWER_NAME" ] || [ "$VIEWER_NAME" = "null" ]; then
    fail "LINEAR_APP_TOKEN didn't authenticate"
    hint "Get a fresh one: bin/get-linear-token"
  elif [ "$VIEWER_NAME" != "claude" ]; then
    warn "Token authenticates as '$VIEWER_NAME' — expected 'claude' (actor=app)"
    hint "Verify the OAuth app's actor setting; see docs/linear-app-setup.md"
  else
    pass "Token authenticates as @claude (actor=app)"
  fi
fi

# --- 4. Worker reachability ----------------------------------------------

phase "Cloudflare Worker"
WORKER_URL="${SSOT_WORKER_URL:-$(kc_get SSOT_WORKER_URL)}"
if [ -z "$WORKER_URL" ]; then
  fail "SSOT_WORKER_URL unknown"
  hint "Set: security add-generic-password -U -s ssot-pipeline -a SSOT_WORKER_URL -w '<url>/config'"
else
  pass "SSOT_WORKER_URL=$WORKER_URL"
  # /config endpoint should return JSON with plan_marker.
  CFG=$(curl -sS --max-time 5 "$WORKER_URL" 2>/dev/null || true)
  if PLAN_MARKER=$(printf '%s' "$CFG" | jq -r '.plan_marker // empty' 2>/dev/null) && [ -n "$PLAN_MARKER" ]; then
    pass "/config reachable (plan_marker=$PLAN_MARKER)"
  else
    fail "/config unreachable or malformed"
    hint "Redeploy: cd worker && npx wrangler deploy"
  fi
  # /health is informational only (Worker may not implement it).
  HEALTH_URL="${WORKER_URL%/config}/health"
  HEALTH=$(curl -sS --max-time 5 -o /dev/null -w '%{http_code}' "$HEALTH_URL" 2>/dev/null || echo 000)
  if [ "$HEALTH" = "200" ]; then
    pass "/health → 200"
  elif [ "$HEALTH" = "404" ]; then
    [ "$QUIET" = "1" ] || hint "/health not implemented (404) — fine if /config is up"
  else
    warn "/health → $HEALTH"
  fi
fi

# --- 5. fork's own GitHub variable + secrets ------------------------------

phase "GitHub Actions config on this fork"
if ! FORK_REPO=$(cd "$REPO_ROOT" && gh repo view --json nameWithOwner --jq .nameWithOwner 2>/dev/null); then
  fail "couldn't detect this fork via 'gh repo view'"
else
  pass "Fork: $FORK_REPO"
  FORK_VARS=$(gh variable list --repo "$FORK_REPO" --json name --jq '.[].name' 2>/dev/null || true)
  if printf '%s\n' "$FORK_VARS" | grep -qx SSOT_WORKER_URL; then
    pass "SSOT_WORKER_URL variable set on fork"
  else
    fail "SSOT_WORKER_URL variable missing on fork"
    hint "Fix: gh variable set SSOT_WORKER_URL --repo $FORK_REPO --body '<url>/config'"
  fi
  if FORK_SECRETS=$(gh secret list --repo "$FORK_REPO" --json name --jq '.[].name' 2>/dev/null); then
    if printf '%s\n' "$FORK_SECRETS" | grep -qx CLOUDFLARE_API_TOKEN; then
      pass "CLOUDFLARE_API_TOKEN set on fork (deploy-worker will run)"
    else
      warn "CLOUDFLARE_API_TOKEN missing on fork — deploy-worker won't auto-redeploy"
      hint "Fix: gh secret set CLOUDFLARE_API_TOKEN --repo $FORK_REPO"
    fi
  fi
fi

# --- 6. each configured target repo ---------------------------------------

phase "Target repos (from config/pipeline.json)"
TARGETS=$(jq -r '.project_to_repo | to_entries[] | "\(.value)"' "$CONFIG" 2>/dev/null | sort -u || true)
for extra in "${EXTRA_REPOS[@]}"; do TARGETS="$TARGETS"$'\n'"$extra"; done
TARGETS=$(printf '%s\n' "$TARGETS" | awk 'NF && !seen[$0]++')

if [ -z "$TARGETS" ]; then
  warn "no target repos configured yet (project_to_repo is empty)"
  hint "Wire one up: ./bin/init-target-repo.sh /path/to/repo <linear-project-url-or-id>"
else
  for repo in $TARGETS; do
    [ "$QUIET" = "1" ] || printf "\n  %s\n" "$repo"
    if ! SECS=$(gh secret list --repo "$repo" --json name --jq '.[].name' 2>/dev/null); then
      fail "$repo: can't list secrets (no access? wrong name?)"
      continue
    fi
    for sec in CLAUDE_CODE_OAUTH_TOKEN LINEAR_APP_TOKEN CLAUDE_REVIEWER_APP_ID CLAUDE_REVIEWER_APP_KEY; do
      if printf '%s\n' "$SECS" | grep -qx "$sec"; then
        pass "$repo / secret $sec"
      else
        fail "$repo / secret $sec missing"
        hint "Fix: ./bin/init-target-repo.sh $repo <linear-project-url-or-id>"
      fi
    done
    if VARS=$(gh variable list --repo "$repo" --json name --jq '.[].name' 2>/dev/null); then
      if printf '%s\n' "$VARS" | grep -qx SSOT_WORKER_URL; then
        pass "$repo / variable SSOT_WORKER_URL"
      else
        fail "$repo / variable SSOT_WORKER_URL missing"
        hint "Fix: gh variable set SSOT_WORKER_URL --repo $repo --body '$WORKER_URL'"
      fi
    fi
  done
fi

# --- summary --------------------------------------------------------------

echo
if [ "$FAIL_COUNT" = "0" ] && [ "$WARN_COUNT" = "0" ]; then
  printf "${C_OK}All checks passed.${C_RESET}\n"
  exit 0
elif [ "$FAIL_COUNT" = "0" ]; then
  printf "${C_WARN}%d warning(s); no failures.${C_RESET}\n" "$WARN_COUNT"
  exit 0
else
  printf "${C_FAIL}%d failure(s)${C_RESET}, %d warning(s).\n" "$FAIL_COUNT" "$WARN_COUNT"
  exit 1
fi
