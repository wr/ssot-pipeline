#!/usr/bin/env python3
"""
Linear OAuth token helper for ssot-pipeline.

Walks you through getting an actor=app token for the `claude` Linear OAuth app:
  1. Prompts for your Client ID + Client Secret (or reads from env)
  2. Opens the Linear authorization URL in your browser
  3. Listens on localhost:8787 for the callback
  4. Exchanges the code for an access token
  5. Prints the token + saves it to ./worker/.dev.vars if you confirm

Usage:
  ./bin/get-linear-token
  LINEAR_CLIENT_ID=... LINEAR_CLIENT_SECRET=... ./bin/get-linear-token
"""

import http.server
import json
import os
import sys
import threading
import urllib.parse
import urllib.request
import webbrowser
from getpass import getpass

PORT = 8787
REDIRECT_URI = f"http://localhost:{PORT}/oauth/callback"
SCOPES = "read,write,issues:create,comments:create,app:assignable,app:mentionable"

captured = {}


class CallbackHandler(http.server.BaseHTTPRequestHandler):
    def do_GET(self):
        parsed = urllib.parse.urlparse(self.path)
        qs = urllib.parse.parse_qs(parsed.query)

        if parsed.path != "/oauth/callback":
            self.send_response(404)
            self.end_headers()
            return

        if "error" in qs:
            captured["error"] = qs["error"][0]
            self._respond(400, f"<h2>OAuth error: {qs['error'][0]}</h2>")
        elif "code" in qs:
            captured["code"] = qs["code"][0]
            self._respond(200, "<h2>Got the code. You can close this tab.</h2>")
        else:
            self._respond(400, "<h2>No code or error in callback.</h2>")

    def _respond(self, status, html):
        self.send_response(status)
        self.send_header("Content-Type", "text/html")
        self.end_headers()
        self.wfile.write(html.encode())

    def log_message(self, *args, **kwargs):
        pass


def main():
    client_id = os.environ.get("LINEAR_CLIENT_ID")
    client_secret = os.environ.get("LINEAR_CLIENT_SECRET")

    if not client_id:
        client_id = input("Linear Client ID: ").strip()
    if not client_secret:
        client_secret = getpass("Linear Client Secret (hidden): ").strip()

    if not client_id or not client_secret:
        print("Missing credentials.", file=sys.stderr)
        sys.exit(1)

    server = http.server.HTTPServer(("localhost", PORT), CallbackHandler)
    thread = threading.Thread(target=server.serve_forever, daemon=True)
    thread.start()

    auth_url = (
        "https://linear.app/oauth/authorize"
        f"?client_id={urllib.parse.quote(client_id)}"
        f"&redirect_uri={urllib.parse.quote(REDIRECT_URI)}"
        "&response_type=code"
        f"&scope={urllib.parse.quote(SCOPES)}"
        "&actor=app"
        "&prompt=consent"
    )

    print("\nOpening Linear authorization in your browser…")
    print(f"If it doesn't open, visit:\n  {auth_url}\n")
    webbrowser.open(auth_url)

    print(f"Listening on {REDIRECT_URI} for the callback (Ctrl-C to abort)…")
    try:
        while "code" not in captured and "error" not in captured:
            threading.Event().wait(0.2)
    except KeyboardInterrupt:
        print("\nAborted.")
        sys.exit(1)
    finally:
        server.shutdown()

    if "error" in captured:
        print(f"OAuth failed: {captured['error']}", file=sys.stderr)
        sys.exit(1)

    code = captured["code"]
    print("Got authorization code. Exchanging for token…")

    body = urllib.parse.urlencode(
        {
            "grant_type": "authorization_code",
            "code": code,
            "redirect_uri": REDIRECT_URI,
            "client_id": client_id,
            "client_secret": client_secret,
        }
    ).encode()

    req = urllib.request.Request(
        "https://api.linear.app/oauth/token",
        data=body,
        headers={"Content-Type": "application/x-www-form-urlencoded"},
    )

    try:
        with urllib.request.urlopen(req) as resp:
            payload = json.loads(resp.read())
    except urllib.error.HTTPError as e:
        print(f"Token exchange failed: {e.code} {e.read().decode()}", file=sys.stderr)
        sys.exit(1)

    token = payload.get("access_token")
    if not token:
        print(f"No access_token in response: {payload}", file=sys.stderr)
        sys.exit(1)

    print("\n✅ Got LINEAR_APP_TOKEN")
    print(f"\n  {token}\n")

    # Verify the token works + check actor identity
    print("Verifying token…")
    verify_req = urllib.request.Request(
        "https://api.linear.app/graphql",
        data=json.dumps({"query": "{ viewer { id name email } }"}).encode(),
        headers={
            "Authorization": token,
            "Content-Type": "application/json",
        },
    )
    try:
        with urllib.request.urlopen(verify_req) as resp:
            data = json.loads(resp.read())
            viewer = data.get("data", {}).get("viewer", {})
            print(f"  viewer.name  = {viewer.get('name')}")
            print(f"  viewer.id    = {viewer.get('id')}")
            print(f"  viewer.email = {viewer.get('email')}")
            if viewer.get("name", "").lower() != "claude":
                print("\n⚠️  viewer.name is not 'claude' — the actor=app param may not have been honored.")
                print("    Check that the app's actor setting in Linear is configured correctly.")
    except Exception as e:
        print(f"  Verify failed: {e}")

    print("\nNext steps:")
    print(f"  export LINEAR_APP_TOKEN='{token}'")
    print("  Then store it as:")
    print("    - a GitHub secret on each target repo (init-target-repo.sh does this)")
    print("    - a Cloudflare Worker secret: cd worker && wrangler secret put LINEAR_APP_TOKEN")


if __name__ == "__main__":
    main()
